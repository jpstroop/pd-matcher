# Groundtruth labeling artifacts (the vault itself IS tracked at data/label_vault.jsonl;
# it is *.jsonl, so the *.db rules below never touch it). Review/queue SQLite DBs
# (review.db, separation_test.db, disagreements.db, and any future ones) plus their
# sqlite sidecars and .bak backups are all build artifacts — ignore them generally.
data/candidates/
data/*.db
data/*.db-journal
data/*.db-shm
data/*.db-wal
data/*.db.bak
data/disagreements.txt

# Harvested renewal-matcher training set (derived, verified-by-transitivity;
# regenerated from the vault + index, never hand-edited). Kept out of git.
data/harvested_renewal_pairs.jsonl

# Training bundle (jpstroop/cce-marc-linkage) is mounted as the data/training
# submodule (vault + marc.xml), not gitignored.
